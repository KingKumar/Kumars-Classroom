{
  "framework": null,
  "installCommand": "npm ci --prefix cell-architecture-studio-main",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/cell-architecture-studio/:path*",
      "destination": "/cell-architecture-studio/index.html"
    },
    {
      "source": "/layers-of-earth/:path*",
      "destination": "/layers-of-earth/index.html"
    },
    {
      "source": "/solar-lunar-eclipses/:path*",
      "destination": "/solar-lunar-eclipses/index.html"
    },
    {
      "source": "/periodic-table-lab/:path*",
      "destination": "/periodic-table-lab/index.html"
    },
    {
      "source": "/forces-motion-playground/:path*",
      "destination": "/forces-motion-playground/index.html"
    },
    {
      "source": "/human-body-systems-explorer/:path*",
      "destination": "/human-body-systems-explorer/index.html"
    },
    {
      "source": "/weather-atmosphere-simulator/:path*",
      "destination": "/weather-atmosphere-simulator/index.html"
    }
  ]
}
